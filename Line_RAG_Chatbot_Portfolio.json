    {
      "parameters": {
        "jsCode": "// ===== Message Parsing =====\n// Support LINE Webhook (events[0]) or general Webhook structure\nconst event = $input.first().json.body.events?.[0] || $json;\nconst message = event.message || {};\nconst replyToken = event.replyToken || '';\nconst userId = event.source?.userId || '';\nconst messageType = message.type || 'text';\nconst messageId = message.id || '';\n\nlet userText = '';\nlet hasImage = false;\nlet hasFile = false;\nlet imageId = '';\nlet fileName = '';\n\nif (messageType === 'text') {\n  userText = (message.text || '').trim();\n  hasImage = false;\n} else if (messageType === 'image') {\n  hasImage = true;\n  imageId = messageId;\n  userText = '[User uploaded an image, please analyze it and answer]';\n} else if (messageType === 'file') {\n  hasFile = true;\n  imageId = messageId;\n  fileName = message.fileName || '';\n  userText = '[User uploaded a file]';\n}\n\n// Check for admin command (upload file)\nconst isUploadCmd = (userText.startsWith('/upload')) ? true : false;\n\n// Check for history command\nconst isHistoryCmd = (userText.startsWith('/history')) ? true : false;\n\n// Check for help command\nconst isHelpCmd = (userText === '/help') ? true : false;\n\nreturn {\n  replyToken,\n  userId,\n  messageType,\n  messageId,\n  userText,\n  hasImage,\n  imageId,\n  hasFile,\n  fileName,\n  isUploadCmd,\n  isHistoryCmd,\n  isHelpCmd\n};"
      },
