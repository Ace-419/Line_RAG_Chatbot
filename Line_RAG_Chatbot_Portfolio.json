    {
      "parameters": {
        "jsCode": "// ===== Compose AI Response and Save to History =====\nconst aiRaw = $json.candidates?.[0]?.content?.parts?.[0]?.text || $json.response || $json.content || $json.text || '(No AI response)';\nconst ctx = $('Format RAG Context').first().json;\nconst replyToken = $('Parse Message').first().json.replyToken;\nconst userId = $('Parse Message').first().json.userId;\nconst userQuestion = ctx.userQuestion;\nconst sourceNames = ctx.sourceNames;\n\nconst responseText = `🤖 AI Response\\n${'─'.repeat(20)}\\n${aiRaw}\\n\\n📄 Sources: ${sourceNames}`;\n\n// Prepare for history log\nconst now = new Date().toLocaleString('en-US');\n\nreturn {\n  text: responseText,\n  replyToken,\n  // History fields\n  timestamp: now,\n  userId,\n  question: userQuestion,\n  ai_reply: aiRaw.substring(0, 500),\n  sources: sourceNames\n};"
      },
