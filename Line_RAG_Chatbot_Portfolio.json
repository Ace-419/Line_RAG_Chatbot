    {
      "parameters": {
        "jsCode": "// ===== Compose Knowledge Context =====\nconst docs = items.map(i => i.json);\n\n// Detect if coming from image analysis path\nlet imageAnalysis = null;\ntry { imageAnalysis = $('Gemini Image Analysis').first().json.candidates[0].content.parts[0].text || null; } catch(e) {}\n\nconst baseQuestion = $('Parse Message').first().json.userText;\nconst userQuestion = imageAnalysis\n  ? `[Image Recognition]\\n${imageAnalysis}\\n\\n[User Message] ${baseQuestion}`\n  : baseQuestion;\n\nlet contextText = \"\";\nlet sources = [];\nif (docs.length > 0) {\n    contextText = docs.map(d => `【Document: ${d.document_name}】\\nContent: ${d.content}`).join('\\n\\n');\n    sources = [...new Set(docs.map(d => d.document_name))];\n} else {\n    contextText = \"No relevant knowledge base data found.\";\n}\n\nreturn {\n    userQuestion,\n    contextText,\n    sourceNames: sources.join(', ') || 'None'\n};"
      },
      "id": "2ed4bedf-c63d-4145-bc96-f03b88bd66b5",
      "name": "Format RAG Context",
