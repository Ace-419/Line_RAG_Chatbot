      "parameters": {
        "jsCode": "// ===== Parse History Query Keyword =====\nconst parsed = $('Parse Message').first().json;\nconst raw = parsed.userText.replace(/^\\/history/i, '').trim();\nconst keyword = raw || '';\nreturn {\n  keyword,\n  replyToken: parsed.replyToken,\n  userId: parsed.userId\n};"
      },
      "id": "3f9d08f6-d6c9-4af2-a8a2-109e3a1ba28f",
      "name": "Parse History Keywords",
      "type": "n8n-nodes-base.code",
