      "notes": "Output 0: Help Menu\nOutput 1: History Query\nOutput 2: File Upload (hasFile)\nOutput 3: Image Analysis (hasImage)\nOutput 4: Upload Command (isUploadCmd)\nOutput 5: General Q&A (fallthrough)"
    },
    {
      "parameters": {
        "jsCode": "// ===== Help Menu =====\nconst helpText = `🤖 AI Knowledge Chatbot User Guide\n\n📚 【Knowledge Base Query】\nEnter your question directly, e.g.:\n  \"What is PLC error 105?\"\n  \"Hydraulic press maintenance SOP\"\n\n🖼️ 【Image Analysis】\nUpload a photo of components/equipment and ask a question.\n\n📋 【Chat History】\n  /history <keyword>\n  Example: /history error 105\n\n📂 【File Upload】\n  /upload\n\n━━━━━━━━━━\n💡 Quick Commands:\n/help - Show this guide\n/history - Query history\n/upload - Manage file upload\n━━━━━━━━━━\n🟢 Support: Please contact the admin.`;\n\nreturn { text: helpText, replyToken: $('Parse Message').first().json.replyToken };"
      },
      "id": "feed7fdf-fc5b-4105-b708-8bc140c1a598",
