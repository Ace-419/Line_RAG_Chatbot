    {
      "parameters": {
        "jsCode": "// ===== Filter History and Format Output =====\nconst keyword = $('Parse History Keywords').first().json.keyword.toLowerCase();\nconst replyToken = $('Parse History Keywords').first().json.replyToken;\n\n// Postgres results\nlet matched = items.map(i => i.json);\n\nif (keyword) {\n  matched = matched.filter(r => {\n    const q = (r.user_text || '').toLowerCase();\n    const a = (r.ai_reply || '').toLowerCase();\n    return q.includes(keyword) || a.includes(keyword);\n  });\n}\n\nlet resultText = `📋 History Query${keyword ? ` (Keyword: ${keyword})` : ' (Recent 5 records)'}\\n${'─'.repeat(20)}`;\n\nif (matched.length === 0) {\n  resultText += '\\n\\n❌ No records found.';\n} else {\n  matched.forEach((r, idx) => {\n    const timeStr = r.created_at ? new Date(r.created_at).toLocaleString('en-US') : '';\n    resultText += `\\n\\n【${idx + 1}】${timeStr}`;\n    resultText += `\\n❓ ${r.user_text || ''}`.substring(0, 100);\n    resultText += `\\n💡 ${r.ai_reply || ''}`.substring(0, 150);\n    if (r.source_documents) resultText += `\\n📄 Source: ${r.source_documents}`;\n  });\n}\n\nreturn { text: resultText, replyToken };"
      },
