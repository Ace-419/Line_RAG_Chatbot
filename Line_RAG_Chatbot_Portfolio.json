        "jsonBody": "={\n  \"content\": {\n    \"parts\": [\n      {\n        \"text\": \"={{ $json.userText || $('Parse Message').first().json.userText || 'What does this mean?' }}\"\n      }\n    ]\n  },\n  \"output_dimensionality\": 768\n}\n",
