      "id": "36b5581e-a477-4177-95ed-cc1582e7d1e1",
      "name": "Get Chat History",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        208,
        768
      ],
      "credentials": {}
