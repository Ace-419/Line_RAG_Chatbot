        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ \n{\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": `Please answer the user's question directly based on the \"Reference Materials\". The answer should be concise, professional, and focus on technical details or SOPs.\n\n⚠️ Instructions:\n1. Get straight to the point, do not have long openings (e.g., Hello, I understand your question) or closings.\n2. If there are troubleshooting steps, SOPs, or technical parameters in the data, be sure to list them completely.\n3. Answer in English with a professional technical tone.\n4. If the reference material is insufficient to answer, please state so directly and provide relevant suggestions from the existing data.\n\n───── Reference Materials ─────\n${$json.contextText}\n\n───── User Question ─────\n${$json.userQuestion}`\n        }\n      ]\n    }\n  ]\n}\n}}",
        "options": {}
